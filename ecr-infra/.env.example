# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# Librus credentials
LIBRUS_USERNAME=
LIBRUS_PASSWORD=
LIBRUS_FULL_NAME=

# British Council credentials (leave blank to disable BC scraping)
BC_USERNAME=
BC_PASSWORD=
BC_ENABLED=false

# Scraping schedule
SCRAPER_INTERVAL_MINUTES=10
SCRAPER_JITTER_MINUTES=3
